<form action="/upload" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="formFile" class="form-label">회의 녹음 파일을 선택하세요 (mp3, wav)</label>
        <input class="form-control" type="file" name="file" id="formFile" required>
    </div>
    <button type="submit" class="btn btn-primary">회의록 분석 시작</button>
</form>